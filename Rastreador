<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Rastreador Chambatina</title>
<style>
body {
    font-family: Arial;
    background: #f5f5f5;
    text-align: center;
    padding: 40px;
}
.container {
    background: white;
    padding: 30px;
    border-radius: 10px;
    max-width: 400px;
    margin: auto;
}
input {
    padding: 10px;
    width: 80%;
    margin-top: 10px;
}
button {
    padding: 10px 20px;
    margin-top: 10px;
    background: orange;
    color: white;
    border: none;
    cursor: pointer;
}
#resultado {
    margin-top: 20px;
    font-weight: bold;
}
</style>
</head>
<body>

<div class="container">
<h2>Rastrea tu paquete</h2>

<input type="text" id="cpk" placeholder="Introduce tu CPK">
<br>
<button onclick="buscar()">Buscar</button>

<div id="resultado"></div>
</div>

<script>
const datos = `
CPK-12345 CLASIFICADO
CPK-67890 ENTREGADO
CPK-11111 EN TRANSITO
`;

function buscar() {
    let input = document.getElementById("cpk").value.trim();
    let resultado = document.getElementById("resultado");

    let lineas = datos.split("\n");

    for (let linea of lineas) {
        if (linea.includes(input)) {
            resultado.innerHTML = "Estado: " + linea.split(" ")[1];
            return;
        }
    }

    resultado.innerHTML = "No encontrado";
}
</script>

</body>
</html> 
