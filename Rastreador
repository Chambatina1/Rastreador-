<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Rastreador Chambatina</title>
  <style>
    body{font-family:Arial,sans-serif;background:#f5f5f5;margin:0;padding:20px;color:#111}
    .card{max-width:900px;margin:0 auto 20px auto;background:#fff;padding:20px;border-radius:16px;box-shadow:0 8px 24px rgba(0,0,0,.08)}
    h1,h2{margin-top:0}
    input,textarea,button{width:100%;padding:12px;margin-top:10px;border-radius:10px;border:1px solid #ccc;box-sizing:border-box;font-size:16px}
    textarea{min-height:220px;font-family:monospace}
    button{background:#111;color:#fff;border:none;font-weight:700}
    .estado{display:inline-block;padding:8px 12px;border-radius:999px;background:#ffe8d3;color:#a14d00;font-weight:700;margin-bottom:12px}
    .ok{font-size:32px;font-weight:900;color:#17803d}
    .res{margin-top:15px;padding:15px;background:#fff8f1;border-left:5px solid #ff7a00;border-radius:10px}
    .err{background:#fff1f1;border-left-color:#c62828}
    .small{font-size:13px;color:#666}
  </style>
</head>
<body>

  <div class="card">
    <h1>Rastreador Chambatina</h1>
    <p>Busca por CPK. Ejemplo: 0260199</p>
    <input id="buscar" placeholder="Escribe el CPK">
    <button onclick="buscarPaquete()">Buscar</button>
    <div id="resultado"></div>
  </div>

  <div class="card">
    <h2>Actualizar datos</h2>
    <p class="small">Formato exacto: una línea por paquete, separada por |</p>
    <p class="small">CPK|ESTADO|FECHA|NOMBRE|DESCRIPCION|DIRECCION|TELEFONO</p>
    <textarea id="datos"></textarea>
    <button onclick="guardarDatos()">Guardar datos en este navegador</button>
    <div id="info" class="small"></div>
  </div>

<script>
var DATOS_BASE = `
0260199|EN AGENCIA|2026-03-25|ROBERTO PACHECO RAMIREZ|BATERIA 51 V 100 AH|SANTIAGO DE CUBA|5353194571
0260197|EN AGENCIA|2026-03-25|ROBERTO PACHECO RAMIREZ|INVERSOR 10 MIL WATTS|SANTIAGO DE CUBA|5353194571
0260020|EN AGENCIA|2026-03-24|NANCY ROJAS REGUERA|MISCELANEAS|LA HABANA VIEJA|53608954
0259575|EN ALMACEN|2026-03-23|FELICIA CARVAJAL MARTIN|MISCELANEAS|VILLA CLARA|53282278
0259555|EN AGENCIA|2026-03-23|OSMANY CASTELLON RAMIREZ|BICICLETA ELECTRICA|CIENFUEGOS|53421145
`;

function limpiarCPK(v){
  return String(v || "").replace(/\D/g,"");
}

function normalizarEstado(e){
  e = String(e || "").toUpperCase().trim();
  if (e.includes("ENTREGADO")) return "ENTREGADO";
  if (e.includes("DISTRIB")) return "DISTRIBUCIÓN";
  if (e.includes("DESPACH")) return "DESPACHO";
  if (e.includes("DESAGRUP")) return "DESAGRUPE";
  if (e.includes("CLASIFIC")) return "CLASIFICADO";
  if (e.includes("AGENCIA")) return "EN AGENCIA";
  if (e.includes("ALMACEN") || e.includes("ALMACÉN")) return "EN ALMACÉN";
  if (e.includes("ARRIBO")) return "ARRIBO";
  if (e.includes("CANAL ROJO")) return "CANAL ROJO";
  return "EN PROCESO";
}

function explicacion(estado){
  switch(estado){
    case "ENTREGADO": return "Su paquete ya fue entregado.";
    case "EN AGENCIA": return "Su paquete ya está en agencia y entra en coordinación de entrega local.";
    case "EN ALMACÉN": return "Su paquete está resguardado en almacén, pendiente del siguiente movimiento.";
    case "CLASIFICADO": return "Su envío ya fue organizado por ruta o provincia.";
    case "DESAGRUPE": return "Su paquete está siendo separado de la carga consolidada.";
    case "DESPACHO": return "Su envío está en fase de despacho.";
    case "DISTRIBUCIÓN": return "Su paquete está en distribución local.";
    case "ARRIBO": return "Su paquete registra arribo a una nueva etapa.";
    case "CANAL ROJO": return "Su envío está bajo revisión adicional.";
    default: return "Su paquete continúa en proceso logístico.";
  }
}

function parsear(texto){
  var base = {};
  var lineas = String(texto || "").split(/\r?\n/);

  for (var i=0; i<lineas.length; i++){
    var l = lineas[i].trim();
    if (!l) continue;

    var p = l.split("|");
    if (p.length < 2) continue;

    var cpk = limpiarCPK(p[0]);
    if (!cpk) continue;

    base[cpk] = {
      cpk: cpk,
      estado: normalizarEstado(p[1] || ""),
      fecha: (p[2] || "").trim(),
      nombre: (p[3] || "").trim(),
      descripcion: (p[4] || "").trim(),
      direccion: (p[5] || "").trim(),
      telefono: (p[6] || "").trim()
    };
  }

  return base;
}

function obtenerBase(){
  var guardado = localStorage.getItem("chambatina_db_simple");
  if (guardado){
    try { return JSON.parse(guardado); } catch(e){}
  }
  return parsear(DATOS_BASE);
}

function guardarDatos(){
  var texto = document.getElementById("datos").value;
  var base = parsear(texto);
  localStorage.setItem("chambatina_db_simple", JSON.stringify(base));
  document.getElementById("info").innerHTML = "Registros guardados: " + Object.keys(base).length;
}

function buscarPaquete(){
  var codigo = limpiarCPK(document.getElementById("buscar").value);
  var base = obtenerBase();
  var r = document.getElementById("resultado");

  if (!codigo){
    r.innerHTML = '<div class="res err">Escribe un CPK válido.</div>';
    return;
  }

  if (!base[codigo]){
    r.innerHTML = '<div class="res err">No encontramos ese CPK.</div>';
    return;
  }

  var x = base[codigo];

  if (x.estado === "ENTREGADO"){
    r.innerHTML =
      '<div class="res"><div class="ok">ENTREGADO</div>' +
      '<p><strong>CPK:</strong> ' + x.cpk + '</p>' +
      '<p><strong>Cliente:</strong> ' + (x.nombre || "No disponible") + '</p>' +
      '<p><strong>Fecha:</strong> ' + (x.fecha || "No disponible") + '</p></div>';
    return;
  }

  r.innerHTML =
    '<div class="res">' +
    '<div class="estado">' + x.estado + '</div>' +
    '<p><strong>CPK:</strong> ' + x.cpk + '</p>' +
    '<p><strong>Cliente:</strong> ' + (x.nombre || "No disponible") + '</p>' +
    '<p><strong>Descripción:</strong> ' + (x.descripcion || "No disponible") + '</p>' +
    '<p><strong>Fecha:</strong> ' + (x.fecha || "No disponible") + '</p>' +
    '<p><strong>Dirección:</strong> ' + (x.direccion || "No disponible") + '</p>' +
    '<p><strong>Teléfono:</strong> ' + (x.telefono || "No disponible") + '</p>' +
    '<p><strong>Explicación:</strong> ' + explicacion(x.estado) + '</p>' +
    '</div>';
}

window.onload = function(){
  document.getElementById("datos").value = DATOS_BASE.trim();
  document.getElementById("info").innerHTML = "Registros listos: " + Object.keys(obtenerBase()).length;
};
</script>
</body>
</html>
