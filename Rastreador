<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chambatina | Rastreo de Paquetería</title>
  <style>
    :root{
      --bg:#0b0b0b;
      --card:#151515;
      --card-2:#1d1d1d;
      --text:#f5f5f5;
      --muted:#bdbdbd;
      --accent:#ff7a00;
      --accent-2:#ffb067;
      --ok:#1fa971;
      --warn:#d89b00;
      --danger:#d64545;
      --border:#2c2c2c;
    }

    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:linear-gradient(180deg,#0b0b0b 0%,#121212 100%);
      color:var(--text);
    }

    .wrap{
      max-width:1000px;
      margin:0 auto;
      padding:24px 16px 60px;
    }

    .hero{
      background:linear-gradient(135deg,#1c1c1c 0%, #121212 60%, #261300 100%);
      border:1px solid var(--border);
      border-radius:20px;
      padding:28px 20px;
      box-shadow:0 10px 30px rgba(0,0,0,.25);
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:10px;
    }

    .logo{
      width:52px;
      height:52px;
      border-radius:14px;
      background:linear-gradient(135deg,var(--accent),#ff5000);
      display:flex;
      align-items:center;
      justify-content:center;
      color:white;
      font-weight:bold;
      font-size:20px;
      box-shadow:0 8px 20px rgba(255,122,0,.25);
    }

    h1{
      margin:0;
      font-size:30px;
      line-height:1.1;
    }

    .sub{
      margin:10px 0 0;
      color:var(--muted);
      font-size:15px;
      line-height:1.5;
    }

    .search-card, .result-card, .timeline-card, .data-card{
      margin-top:18px;
      background:var(--card);
      border:1px solid var(--border);
      border-radius:18px;
      padding:18px;
      box-shadow:0 8px 20px rgba(0,0,0,.18);
    }

    .search-row{
      display:grid;
      grid-template-columns:1fr auto;
      gap:12px;
      margin-top:12px;
    }

    input, textarea, button{
      font:inherit;
    }

    .search-input{
      width:100%;
      padding:16px 14px;
      background:#0e0e0e;
      color:var(--text);
      border:1px solid #333;
      border-radius:14px;
      outline:none;
      font-size:16px;
    }

    .search-input:focus,
    textarea:focus{
      border-color:var(--accent);
      box-shadow:0 0 0 3px rgba(255,122,0,.12);
    }

    .btn{
      border:none;
      cursor:pointer;
      border-radius:14px;
      padding:15px 18px;
      background:linear-gradient(135deg,var(--accent),#ff5a00);
      color:#fff;
      font-weight:bold;
      min-width:150px;
      transition:.2s ease;
    }

    .btn:hover{transform:translateY(-1px)}
    .btn.secondary{
      background:#232323;
      border:1px solid #383838;
      color:#fff;
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:12px;
      margin-top:14px;
    }

    .info-box{
      background:var(--card-2);
      border:1px solid var(--border);
      border-radius:14px;
      padding:14px;
    }

    .label{
      color:var(--muted);
      font-size:13px;
      margin-bottom:6px;
      text-transform:uppercase;
      letter-spacing:.4px;
    }

    .value{
      font-size:16px;
      font-weight:bold;
      line-height:1.4;
    }

    .status-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 14px;
      border-radius:999px;
      font-weight:bold;
      margin-top:10px;
      border:1px solid transparent;
    }

    .status-default{background:#2c2418;color:#ffd4a3;border-color:#5b3c0c}
    .status-ok{background:#10291f;color:#8ef0c8;border-color:#1d6d4c}
    .status-warn{background:#2f2712;color:#ffdd88;border-color:#866400}
    .status-danger{background:#341616;color:#ffaaaa;border-color:#8c3737}

    .message{
      margin-top:14px;
      background:#111;
      border-left:4px solid var(--accent);
      padding:14px;
      border-radius:12px;
      color:#f2f2f2;
      line-height:1.6;
    }

    .timeline{
      display:grid;
      gap:12px;
      margin-top:12px;
    }

    .step{
      display:grid;
      grid-template-columns:54px 1fr;
      gap:12px;
      align-items:flex-start;
      background:var(--card-2);
      border:1px solid var(--border);
      border-radius:16px;
      padding:14px;
      position:relative;
      overflow:hidden;
    }

    .step-number{
      width:40px;
      height:40px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:bold;
      background:#2b2b2b;
      border:1px solid #454545;
      color:#fff;
      margin-top:2px;
    }

    .step.active{
      border-color:#8a4b09;
      box-shadow:0 0 0 2px rgba(255,122,0,.08) inset;
    }

    .step.active .step-number{
      background:linear-gradient(135deg,var(--accent),#ff5a00);
      border-color:transparent;
    }

    .step.done{
      border-color:#205a42;
    }

    .step.done .step-number{
      background:linear-gradient(135deg,#1fa971,#197a54);
      border-color:transparent;
    }

    .step-title{
      font-size:17px;
      font-weight:bold;
      margin-bottom:4px;
    }

    .step-days{
      color:var(--accent-2);
      font-size:13px;
      margin-bottom:6px;
    }

    .step-text{
      color:#e8e8e8;
      line-height:1.5;
      font-size:14px;
    }

    .small{
      color:var(--muted);
      font-size:13px;
      line-height:1.5;
    }

    .hidden{
      display:none !important;
    }

    .data-card h3{
      margin-top:0;
    }

    textarea{
      width:100%;
      min-height:280px;
      resize:vertical;
      padding:14px;
      background:#0f0f0f;
      color:#f5f5f5;
      border:1px solid #333;
      border-radius:14px;
      line-height:1.45;
    }

    .footer-note{
      margin-top:18px;
      color:#a9a9a9;
      font-size:12px;
      line-height:1.6;
    }

    .top-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }

    @media (max-width: 700px){
      .search-row{
        grid-template-columns:1fr;
      }
      .grid{
        grid-template-columns:1fr;
      }
      h1{
        font-size:24px;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div class="brand">
        <div class="logo">C</div>
        <div>
          <h1>Rastreo de Paquetería Chambatina</h1>
          <div class="small">Consulta el avance logístico de tu envío con tu número de rastreo o CPK.</div>
        </div>
      </div>
      <p class="sub">
        Introduce tu número y el sistema te mostrará el estado actual del paquete, la fecha de entrada
        y una ruta logística estimada por etapas cada 3 días.
      </p>
    </section>

    <section class="search-card">
      <div class="label">Buscar paquete</div>
      <div class="search-row">
        <input id="trackingInput" class="search-input" type="text" placeholder="Ejemplo: 0259557 o CPK-0259557" />
        <button id="searchBtn" class="btn">Buscar ahora</button>
      </div>

      <div class="top-actions">
        <button id="toggleAdminBtn" class="btn secondary" type="button">Modo administrador</button>
      </div>
    </section>

    <section id="resultCard" class="result-card hidden">
      <div class="label">Resultado</div>
      <div id="statusBadge" class="status-badge status-default">Estado pendiente</div>

      <div class="grid">
        <div class="info-box">
          <div class="label">Número</div>
          <div id="resCode" class="value">-</div>
        </div>
        <div class="info-box">
          <div class="label">Fecha de entrada</div>
          <div id="resDate" class="value">-</div>
        </div>
        <div class="info-box">
          <div class="label">Cliente</div>
          <div id="resName" class="value">-</div>
        </div>
        <div class="info-box">
          <div class="label">Descripción</div>
          <div id="resDesc" class="value">-</div>
        </div>
      </div>

      <div id="mainMessage" class="message"></div>
    </section>

    <section id="timelineCard" class="timeline-card hidden">
      <div class="label">Ruta logística estimada</div>
      <div id="timeline" class="timeline"></div>
    </section>

    <section id="adminCard" class="data-card hidden">
      <h3>Modo administrador</h3>
      <p class="small">
        Aquí puedes pegar tus datos crudos. Luego pulsa <strong>Actualizar vista</strong>.
        Este panel está pensado para que tú copies y pegues con facilidad.
      </p>

      <textarea id="rawDataEditor"></textarea>

      <div class="top-actions">
        <button id="applyDataBtn" class="btn" type="button">Actualizar vista</button>
        <button id="resetDataBtn" class="btn secondary" type="button">Restaurar datos base</button>
      </div>

      <div class="footer-note">
        Nota técnica: en GitHub Pages este panel funciona en el navegador actual. Si quieres que el cambio
        quede público para todos, actualiza también el contenido de <strong>RAW_DATA</strong> dentro del archivo
        y vuelve a subir el <strong>index.html</strong> al repositorio.
      </div>
    </section>
  </div>

  <script>
    /*
      ============================================================
      ZONA FÁCIL PARA PEGAR TUS DATOS CRUDOS
      ============================================================
      Puedes pegar líneas desordenadas con CPK, estado, fecha, nombre, producto, etc.

      EJEMPLOS QUE EL SISTEMA INTENTA LEER:
      CPK-0259557 EN ALMACEN 2026-03-23 OSMANY CASTELLON RAMIREZ VENTILADOR DE TECHO
      CPK-0259555 EN AGENCIA 2026-03-23 YUMIN SORIANO ARIAS BICICLETA ELECTRICA
      CPK-0259554 CLASIFICADO 2026-03-20 MARIA PEREZ PLANTA ECOFLOW

      También sirve si pegas líneas tabuladas desde Excel o sistemas.
    */
    const RAW_DATA = String.raw`
CHAMBATINA MIAMI  GEO MIA  CPK-0259557  EN ALMACEN  2026-03-23  OSMANY CASTELLON RAMIREZ  VENTILADOR DE TECHO
CHAMBATINA MIAMI  GEO MIA  CPK-0259555  EN AGENCIA  2026-03-23  YUMIN SORIANO ARIAS  BICICLETA ELECTRICA
CHAMBATINA MIAMI  GEO MIA  CPK-0259554  CLASIFICADO  2026-03-20  MARIA PEREZ  ECOFLOW DELTA 2
CHAMBATINA MIAMI  GEO MIA  CPK-0259553  DESPACHO  2026-03-18  JUAN RODRIGUEZ  INVERSOR 3500W
CHAMBATINA MIAMI  GEO MIA  CPK-0259552  ENTREGADO  2026-03-10  ANA SUAREZ  PANEL SOLAR 550W
`;

    const STATUS_MAP = {
      "ENTREGADO": {
        badgeClass: "status-ok",
        label: "ENTREGADO",
        message: "Tu paquete fue entregado correctamente. Gracias por confiar en Chambatina."
      },
      "EN AGENCIA": {
        badgeClass: "status-warn",
        label: "EN AGENCIA",
        message: "Tu paquete ya está ubicado en agencia y continúa su flujo logístico normal."
      },
      "EN ALMACEN": {
        badgeClass: "status-warn",
        label: "EN ALMACÉN",
        message: "Tu paquete fue recibido y se encuentra bajo control logístico en almacén."
      },
      "CLASIFICADO": {
        badgeClass: "status-warn",
        label: "CLASIFICADO",
        message: "Tu paquete fue identificado, revisado y ubicado dentro del flujo correspondiente para su salida o distribución."
      },
      "DESAGRUPE": {
        badgeClass: "status-warn",
        label: "DESAGRUPE",
        message: "Tu paquete está siendo separado del contenedor o carga consolidada para continuar la distribución."
      },
      "DESPACHO": {
        badgeClass: "status-warn",
        label: "DESPACHO",
        message: "Tu paquete se encuentra en fase de despacho, avanzando hacia la siguiente etapa logística."
      },
      "DISTRIBUCION": {
        badgeClass: "status-warn",
        label: "DISTRIBUCIÓN",
        message: "Tu paquete está en distribución hacia su destino final dentro de la ruta operativa."
      },
      "ARRIBO": {
        badgeClass: "status-warn",
        label: "ARRIBO",
        message: "Tu paquete ya registró arribo dentro del circuito logístico y continúa su procesamiento."
      },
      "CANAL ROJO": {
        badgeClass: "status-danger",
        label: "CANAL ROJO",
        message: "Tu paquete requiere una revisión adicional dentro del proceso logístico. Esto puede generar demoras normales."
      }
    };

    const TIMELINE_STEPS = [
      {
        title: "Recepción inicial",
        days: "Días 0 al 2",
        text: "El paquete entra al sistema, se recibe físicamente, se valida su llegada y se registra su número para seguimiento."
      },
      {
        title: "Verificación y etiquetado",
        days: "Días 3 al 5",
        text: "Se revisan los datos básicos del envío, se confirma la identificación del paquete y se prepara para el flujo interno."
      },
      {
        title: "Clasificación logística",
        days: "Días 6 al 8",
        text: "El paquete se clasifica según ruta, tipo de mercancía y destino operativo para integrarlo al movimiento correcto."
      },
      {
        title: "Consolidación de carga",
        days: "Días 9 al 11",
        text: "La mercancía se agrupa con otros envíos compatibles para optimizar salida, control y manejo logístico."
      },
      {
        title: "Preparación de despacho",
        days: "Días 12 al 14",
        text: "Se organiza la documentación operativa y el paquete se prepara para la siguiente transferencia dentro del sistema."
      },
      {
        title: "Salida hacia agencia o punto logístico",
        days: "Días 15 al 17",
        text: "El envío avanza desde el punto de manejo inicial hacia la agencia, operador o fase siguiente del trayecto."
      },
      {
        title: "Proceso logístico intermedio",
        days: "Días 18 al 20",
        text: "El paquete continúa en tránsito o procesamiento interno mientras se acerca a la etapa final de distribución."
      },
      {
        title: "Distribución o cierre de ruta",
        days: "Días 21 en adelante",
        text: "El paquete entra en distribución final, entrega o confirmación de cierre según el estado real reportado."
      }
    ];

    function normalizeText(value) {
      return (value || "")
        .toString()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/\s+/g, " ")
        .trim()
        .toUpperCase();
    }

    function normalizeCode(value) {
      return (value || "")
        .toString()
        .toUpperCase()
        .replace(/CPK/g, "")
        .replace(/[^0-9]/g, "");
    }

    function parseDateFromLine(line) {
      const iso = line.match(/\b(20\d{2}-\d{2}-\d{2})\b/);
      if (iso) return iso[1];

      const dmy = line.match(/\b(\d{2})[\/\-](\d{2})[\/\-](20\d{2})\b/);
      if (dmy) {
        const dd = dmy[1];
        const mm = dmy[2];
        const yyyy = dmy[3];
        return `${yyyy}-${mm}-${dd}`;
      }
      return "";
    }

    function formatDate(isoDate) {
      if (!isoDate) return "-";
      const parts = isoDate.split("-");
      if (parts.length !== 3) return isoDate;
      return `${parts[2]}/${parts[1]}/${parts[0]}`;
    }

    function safeDate(isoDate) {
      const d = new Date(isoDate + "T00:00:00");
      return isNaN(d.getTime()) ? null : d;
    }

    function diffDays(fromDateStr) {
      const from = safeDate(fromDateStr);
      if (!from) return 0;
      const now = new Date();
      const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const ms = today - from;
      return Math.max(0, Math.floor(ms / 86400000));
    }

    function findStatusInLine(line) {
      const normalized = normalizeText(line);
      const keys = Object.keys(STATUS_MAP).sort((a,b) => b.length - a.length);
      for (const key of keys) {
        if (normalized.includes(normalizeText(key))) return key;
      }
      return "";
    }

    function extractCode(line) {
      const match = line.match(/CPK[\-\s]*0*([0-9]{4,})/i) || line.match(/\b0*([0-9]{5,})\b/);
      return match ? match[1] : "";
    }

    function guessName(line) {
      const clean = line.replace(/\t/g, " ").replace(/\s+/g, " ").trim();
      const date = parseDateFromLine(clean);
      const withoutCode = clean.replace(/CPK[\-\s]*0*[0-9]{4,}/ig, " ");
      const withoutDate = date ? withoutCode.replace(date, " ") : withoutCode;
      const withoutStatus = Object.keys(STATUS_MAP).reduce((acc, key) => {
        const regex = new RegExp(key.replace(/\s+/g, "\\s+"), "ig");
        return acc.replace(regex, " ");
      }, withoutDate);

      const words = withoutStatus
        .split(" ")
        .map(s => s.trim())
        .filter(Boolean);

      const nameWords = [];
      for (const w of words) {
        if (/^[A-ZÁÉÍÓÚÑ][A-ZÁÉÍÓÚÑa-záéíóúñ]+$/.test(w)) {
          nameWords.push(w);
          if (nameWords.length >= 4) break;
        }
      }

      return nameWords.join(" ") || "No especificado";
    }

    function guessDescription(line, status, date, code, name) {
      let out = line;
      if (code) out = out.replace(new RegExp(`CPK[\\-\\s]*0*${code}`, "ig"), " ");
      if (date) out = out.replace(date, " ");
      if (status) out = out.replace(new RegExp(status.replace(/\s+/g, "\\s+"), "ig"), " ");
      if (name && name !== "No especificado") {
        const escaped = name.replace(/[.*+?^${}()|[\]\\]/g, "\\$&").replace(/\s+/g, "\\s+");
        out = out.replace(new RegExp(escaped, "ig"), " ");
      }

      out = out.replace(/\s+/g, " ").trim();
      if (!out) return "Paquete registrado en sistema";
      return out.length > 120 ? out.slice(0, 120) + "..." : out;
    }

    function parseRawData(raw) {
      const lines = raw
        .split(/\r?\n/)
        .map(line => line.trim())
        .filter(Boolean);

      const map = {};

      for (const line of lines) {
        const code = extractCode(line);
        if (!code) continue;

        const date = parseDateFromLine(line) || "";
        const status = findStatusInLine(line) || "";
        const name = guessName(line);
        const description = guessDescription(line, status, date, code, name);

        map[normalizeCode(code)] = {
          code: normalizeCode(code),
          rawLine: line,
          date,
          status,
          name,
          description
        };
      }

      return map;
    }

    function buildEstimatedStatus(days) {
      if (days >= 21) return "DISTRIBUCION";
      if (days >= 18) return "ARRIBO";
      if (days >= 15) return "DESPACHO";
      if (days >= 12) return "DESAGRUPE";
      if (days >= 9) return "CLASIFICADO";
      if (days >= 6) return "CLASIFICADO";
      if (days >= 3) return "EN ALMACEN";
      return "EN ALMACEN";
    }

    function getStageIndex(days, status) {
      if (normalizeText(status) === "ENTREGADO") return 7;
      return Math.min(7, Math.floor(days / 3));
    }

    function getStatusDisplay(statusKey) {
      const key = normalizeText(statusKey);
      return STATUS_MAP[key] || {
        badgeClass: "status-default",
        label: key || "EN PROCESO",
        message: "Tu paquete está dentro del flujo logístico normal y continúa avanzando por etapas."
      };
    }

    function renderTimeline(days, actualStatus) {
      const timeline = document.getElementById("timeline");
      timeline.innerHTML = "";

      const stageIndex = getStageIndex(days, actualStatus);

      TIMELINE_STEPS.forEach((step, index) => {
        const div = document.createElement("div");
        div.className = "step";

        if (index < stageIndex) div.classList.add("done");
        if (index === stageIndex) div.classList.add("active");
        if (normalizeText(actualStatus) === "ENTREGADO" && index <= 7) div.classList.add("done");

        div.innerHTML = `
          <div class="step-number">${index + 1}</div>
          <div>
            <div class="step-title">${step.title}</div>
            <div class="step-days">${step.days}</div>
            <div class="step-text">${step.text}</div>
          </div>
        `;
        timeline.appendChild(div);
      });
    }

    function renderResult(record) {
      const resultCard = document.getElementById("resultCard");
      const timelineCard = document.getElementById("timelineCard");
      const statusBadge = document.getElementById("statusBadge");

      const days = diffDays(record.date);
      const estimated = buildEstimatedStatus(days);
      const finalStatus = record.status || estimated;
      const statusView = getStatusDisplay(finalStatus);

      document.getElementById("resCode").textContent = "CPK-" + record.code.padStart(7, "0");
      document.getElementById("resDate").textContent = formatDate(record.date);
      document.getElementById("resName").textContent = record.name || "No especificado";
      document.getElementById("resDesc").textContent = record.description || "Paquete registrado";

      statusBadge.className = "status-badge " + statusView.badgeClass;
      statusBadge.textContent = statusView.label;

      const message = document.getElementById("mainMessage");
      if (normalizeText(finalStatus) === "ENTREGADO") {
        message.innerHTML = `
          Tu paquete aparece como <strong>ENTREGADO</strong>. El proceso logístico quedó finalizado.
        `;
      } else {
        message.innerHTML = `
          ${statusView.message}<br><br>
          <strong>Días transcurridos desde la entrada:</strong> ${days}<br>
          <strong>Seguimiento estimado por etapas:</strong> el sistema muestra el movimiento logístico según bloques de 3 días.
        `;
      }

      resultCard.classList.remove("hidden");
      timelineCard.classList.remove("hidden");
      renderTimeline(days, finalStatus);
    }

    function renderNotFound(searchValue) {
      const resultCard = document.getElementById("resultCard");
      const timelineCard = document.getElementById("timelineCard");
      const statusBadge = document.getElementById("statusBadge");

      resultCard.classList.remove("hidden");
      timelineCard.classList.add("hidden");

      statusBadge.className = "status-badge status-danger";
      statusBadge.textContent = "NO ENCONTRADO";

      document.getElementById("resCode").textContent = searchValue || "-";
      document.getElementById("resDate").textContent = "-";
      document.getElementById("resName").textContent = "-";
      document.getElementById("resDesc").textContent = "-";

      document.getElementById("mainMessage").innerHTML = `
        No se encontró un paquete con ese número en la base cargada actualmente.
        Verifica el número e intenta de nuevo.
      `;
    }

    function getStorageData() {
      return localStorage.getItem("chambatina_raw_data") || RAW_DATA;
    }

    function setStorageData(value) {
      localStorage.setItem("chambatina_raw_data", value);
    }

    function searchPackage() {
      const input = document.getElementById("trackingInput");
      const query = normalizeCode(input.value);

      if (!query) {
        renderNotFound("-");
        return;
      }

      const raw = getStorageData();
      const db = parseRawData(raw);
      const record = db[query];

      if (record) {
        renderResult(record);
      } else {
        renderNotFound("CPK-" + query.padStart(7, "0"));
      }
    }

    function initAdminPanel() {
      const adminCard = document.getElementById("adminCard");
      const toggleAdminBtn = document.getElementById("toggleAdminBtn");
      const rawDataEditor = document.getElementById("rawDataEditor");
      const applyDataBtn = document.getElementById("applyDataBtn");
      const resetDataBtn = document.getElementById("resetDataBtn");

      rawDataEditor.value = getStorageData();

      toggleAdminBtn.addEventListener("click", () => {
        adminCard.classList.toggle("hidden");
      });

      applyDataBtn.addEventListener("click", () => {
        setStorageData(rawDataEditor.value);
        alert("Datos cargados en esta vista. Ahora puedes probar la búsqueda.");
      });

      resetDataBtn.addEventListener("click", () => {
        rawDataEditor.value = RAW_DATA;
        setStorageData(RAW_DATA);
        alert("Se restauraron los datos base del archivo.");
      });
    }

    document.getElementById("searchBtn").addEventListener("click", searchPackage);
    document.getElementById("trackingInput").addEventListener("keydown", (e) => {
      if (e.key === "Enter") searchPackage();
    });

    initAdminPanel();
  </script>
</body>
</html>
